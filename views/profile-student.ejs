<!DOCTYPE html>
<html>
    <head>
        <title>Student Profile - OrgSpace</title>
        <link rel="stylesheet" href="/style.css">
    </head>

    <body>
        <main>
            <nav id="menu">
                <span class="menu-title">DLSU Organizations</span>
                <input type="checkbox" id="responsive-menu"><label></label>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a class="dropdown-arrow" href="#organizations">Organizations</a>
                        <ul class="sub-menus">
                            <li><a href="/org1">Archers for UNICEF</a></li>
                            <li><a href="/org2">Council of Student Organizations</a></li>
                            <li><a href="/org3">Information Security Organization</a></li>
                            <li><a href="/org4">La Salle Computer Society</a></li>
                            <li><a href="/org5">Management of Financial Institutions Association</a></li>
                        </ul>
                    </li>
                    <li><a href="/contact">Contact Us</a></li>
                    <li class="menu-profile" id="profileMenu">
                        <button class="profile-btn" id="profileBtn" aria-haspopup="true" aria-expanded="false">
                            <img src="/assets/profile-icon.png" alt="Account" class="profile-icon">
                        </button>
                        <ul class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Account menu"></ul>
                    </li>
                </ul>
            </nav>

            <div class="profile-container" id="profileContent" style="display: none;">
                <div class="profile-header" style="display: flex; align-items: center; gap: 30px;">
                    <img id="profileImage" src="" alt="Profile" class="profile-pic-large">
                    <div>
                        <h1 id="studentName" style="color: white; margin-bottom: 10px;"></h1>
                        <p id="studentCollegeHeader" style="font-size: 1.1rem; opacity: 0.9;"></p>
                        <div class="profile-actions">
                            <button onclick="editProfile()" class="btn-action">✏️ Edit Profile</button>
                            <button onclick="viewOrganizations()" class="btn-action">🏢 Browse Organizations</button>
                        </div>
                    </div>
                </div>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div>🎯</div>
                        <h4 id="organizationsJoined">0</h4>
                        <p>Organizations Joined</p>
                    </div>
                    <div class="stat-card">
                        <div>📅</div>
                        <h4 id="upcomingEvents">0</h4>
                        <p>Upcoming Events</p>
                    </div>
                    <div class="stat-card">
                        <div>💬</div>
                        <h4 id="commentsMade">0</h4>
                        <p>Comments Made</p>
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-card">
                        <h3>Personal Information</h3>
                        <p><strong>🎓 Student ID:</strong> <span id="studentId"></span></p>
                        <p><strong>📧 Email:</strong> <span id="studentEmail"></span></p>
                        <p><strong>🏫 College:</strong> <span id="studentCollege"></span></p>
                        <div style="margin-top: 20px;">
                            <h4 style="color: #046307; margin-bottom: 10px;">Status</h4>
                            <span class="tag" style="background: #4caf50;">Active Student</span>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3>Account Settings</h3>
                        <p><strong>🔐 Last Login:</strong> <span id="lastLogin">Today, 09:30 AM</span></p>
                        <p><strong>📱 Notification:</strong> <span id="notifications">Enabled</span></p>
                        <div style="margin-top: 20px;">
                            <h4 style="color: #046307; margin-bottom: 10px;">Quick Actions</h4>
                            <button onclick="changePassword()" class="btn-action" style="margin-bottom: 10px; width: 100%;">
                                🔐 Change Password
                            </button>
                            <button onclick="logout()" class="btn-action" style="background: #f44336; width: 100%;">
                                🚪 Logout
                            </button>
                        </div>
                    </div>

                    <div class="info-card">
                        <h3>Joined Organizations</h3>
                        <div id="organizationsList">
                            <p>🏹 <strong>Archers for UNICEF</strong> - Member since 2025</p>
                            <p>💻 <strong>La Salle Computer Society</strong> - Member since 2024</p>
                            <p>🔒 <strong>Information Security Organization</strong> - Member since 2024</p>
                        </div>
                        <button onclick="browseOrganizations()" class="btn-action" style="margin-top: 15px; width: 100%;">
                            🔍 Browse More Organizations
                        </button>
                    </div>

                    <div class="info-card">
                        <h3>Recent Activities</h3>
                        <div id="recentActivities">
                            <p>💬 <strong>Commented</strong> on AU 2nd General Assembly - Today</p>
                            <p>📝 <strong>Registered</strong> for LSCS Hackathon - Yesterday</p>
                            <p>🏹 <strong>Joined</strong> Archers for UNICEF - Last week</p>
                        </div>
                    </div>
                </div>

                <div style="background: #e9f5e9; padding: 25px; border-radius: 14px; border: 2px solid #046307; margin-top: 30px;">
 
                </div>
            </div>

            <div id="loadingMessage" style="text-align: center; padding: 50px;">
                <p>Loading student profile...</p>
            </div>

            <div id="editModal" class="modal-overlay" style="display: none;">
                <div class="modal-content">
                    <span class="close-modal" onclick="closeEditModal()">&times;</span>
                    <h2>Edit Student Profile</h2>
                    <form id="editStudentForm">
                        <div class="form-group">
                            <label for="editFirstName">First Name</label>
                            <input type="text" id="editFirstName" name="firstName" required>
                        </div>

                        <div class="form-group">
                            <label for="editLastName">Last Name</label>
                            <input type="text" id="editLastName" name="lastName" required>
                        </div>

                        <div class="form-group">
                            <label for="editEmail">Email</label>
                            <input type="email" id="editEmail" name="email" required>
                        </div>

                        <div class="form-group">
                            <label for="editCollege">College</label>
                            <input type="text" id="editCollege" name="college" required>
                        </div>

                        <div class="form-group">
                            <label for="editStudentId">Student ID</label>
                            <input type="text" id="editStudentId" name="studentId" disabled>
                        </div>

                        <div class="form-actions">
                            <button type="button" onclick="closeEditModal()" class="btn-secondary">Cancel</button>
                            <button type="button" onclick="saveStudentProfile()" class="btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>

            <script src="/script.js"></script>

            <script id="user-json" type="application/json">
                <%- JSON.stringify(user || {}) %>
            </script>

            <script>
                let currentUser = {};

                document.addEventListener('DOMContentLoaded', function () {
                    document.getElementById('loadingMessage').style.display = 'none';
                    document.getElementById('profileContent').style.display = 'block';

                    currentUser = JSON.parse(document.getElementById('user-json').textContent || "{}");
                    initializeProfile(currentUser);
                });

                function initializeProfile(user) {
                    currentUser = user || {};

                    const studentData = {
                        firstName: currentUser.firstName || "",
                        lastName: currentUser.lastName || "",
                        studentId: currentUser.studentId || "",
                        email: currentUser.email || "",
                        college: currentUser.college || "",
                        profileImage: currentUser.profileImage || "/assets/default-profile.png",
                        organizationsJoined: currentUser.organizationsJoined || 3,
                        upcomingEvents: currentUser.upcomingEvents || 2,
                        commentsMade: currentUser.commentsMade || 15,
                        lastLogin: currentUser.lastLogin || "Today, 09:30 AM",
                        notifications: currentUser.notifications || "Enabled"
                    };

                    document.getElementById('profileImage').src = studentData.profileImage;
                    document.getElementById('studentName').textContent = `${studentData.firstName} ${studentData.lastName}`.trim();
                    document.getElementById('studentCollegeHeader').textContent = studentData.college;
                    document.getElementById('studentId').textContent = studentData.studentId;
                    document.getElementById('studentEmail').textContent = studentData.email;
                    document.getElementById('studentCollege').textContent = studentData.college;
                    document.getElementById('organizationsJoined').textContent = studentData.organizationsJoined;
                    document.getElementById('upcomingEvents').textContent = studentData.upcomingEvents;
                    document.getElementById('commentsMade').textContent = studentData.commentsMade;
                    document.getElementById('lastLogin').textContent = studentData.lastLogin;
                    document.getElementById('notifications').textContent = studentData.notifications;
                }

                function openEditModal() {
                    document.getElementById('editFirstName').value = currentUser.firstName || '';
                    document.getElementById('editLastName').value = currentUser.lastName || '';
                    document.getElementById('editEmail').value = currentUser.email || '';
                    document.getElementById('editCollege').value = currentUser.college || '';
                    document.getElementById('editStudentId').value = currentUser.studentId || '';

                    document.getElementById('editModal').style.display = 'flex';
                }

                function closeEditModal() {
                    document.getElementById('editModal').style.display = 'none';
                }

                async function saveStudentProfile() {
                    const firstName = document.getElementById('editFirstName').value.trim();
                    const lastName = document.getElementById('editLastName').value.trim();
                    const email = document.getElementById('editEmail').value.trim();
                    const college = document.getElementById('editCollege').value.trim();

                    if (!firstName || !lastName || !email || !college) {
                        alert('All fields are required!');
                        return;
                    }

                    try {
                        const response = await fetch("/edit-profile/student", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                firstName,
                                lastName,
                                email,
                                college
                            })
                        });

                        const result = await response.json();

                        if (result.success) {
                            currentUser.firstName = firstName;
                            currentUser.lastName = lastName;
                            currentUser.email = email;
                            currentUser.college = college;

                            initializeProfile(currentUser);
                            closeEditModal();
                            alert('Profile updated successfully!');
                        } else {
                            alert(result.message || 'Failed to update profile.');
                        }
                    } catch (error) {
                        console.error("Save profile error:", error);
                        alert("Something went wrong while saving profile.");
                    }
                }

                function editProfile() {
                    openEditModal();
                }

                function logout() {
                    window.location.href = "/logout";
                }

                function viewOrganizations() {
                    window.location.href = "/#organizations";
                }

                function viewEvents() {
                    alert('Opening event calendar...');
                }

                function browseOrganizations() {
                    window.location.href = "/#organizations";
                }
                
                async function changePassword() {

                  const currentPassword = prompt("Enter current password:");
                  if (!currentPassword) return;

                  const newPassword = prompt("Enter new password:");
                  if (!newPassword) return;

                  const res = await fetch("/change-password", {
                    method: "POST",
                    headers: {
                      "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                      currentPassword,
                      newPassword
                    })
                  });

                  const data = await res.json();

                  if (data.success) {
                    alert("Password changed successfully!");
                  } else {
                    alert(data.message || "Error changing password");
                  }

                }


                function viewCalendar() {
                    alert('Opening event calendar...');
                }

                function viewMessages() {
                    alert('Opening messages...');
                }

                function viewNotifications() {
                    alert('Opening notifications...');
                }

                window.addEventListener('click', function(event) {
                    const modal = document.getElementById('editModal');
                    if (event.target === modal) {
                        closeEditModal();
                    }
                });

                document.addEventListener('keydown', function(event) {
                    if (event.key === 'Escape') {
                        closeEditModal();
                    }
                });
            </script>
        </main>
    </body>
</html>